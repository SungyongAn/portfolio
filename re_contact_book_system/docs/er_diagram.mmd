    users ||--o{ student_class_assignments : "学生として所属"
    users ||--o{ teacher_assignments : "教師として割当"
    users ||--o{ journal_entries : "日誌を作成"
    users ||--o{ journal_entries : "日誌を既読"
    users ||--o{ teacher_notes : "教師として記録"
    users ||--o{ teacher_notes : "学生について記録"
    
    grades ||--o{ classes : "学年に属する"
    grades ||--o{ teacher_assignments : "学年担当"
    
    classes ||--o{ student_class_assignments : "クラスに割当"
    classes ||--o{ teacher_assignments : "クラス担当"
    
    journal_entries ||--o{ teacher_notes : "日誌に紐付く"
    
    users {
        int id PK
        string email UK "ログインID"
        string password_hash
        enum role "student/teacher/admin"
        string name
        timestamp created_at
        timestamp updated_at
    }
    
    grades {
        int id PK
        int grade_number "1,2,3"
        int year "2025,2026"
        timestamp created_at
    }
    
    classes {
        int id PK
        int grade_id FK
        string class_name "A組,B組"
        timestamp created_at
    }
    
    student_class_assignments {
        int id PK
        int student_id FK
        int class_id FK
        boolean is_current "現在のクラスか"
        timestamp assigned_at
    }
    
    teacher_assignments {
        int id PK
        int teacher_id FK
        enum assignment_type "homeroom/subject/grade_head/administrator"
        int grade_id FK "nullable"
        int class_id FK "nullable"
        string subject_name "nullable"
        boolean is_primary
        enum permission_level "read/write/admin"
        timestamp created_at
    }
    
    journal_entries {
        int id PK
        int student_id FK
        date entry_date "記入対象日"
        date submission_date "提出日"
        string physical_condition "体調"
        string mental_condition "メンタル"
        text reflection_text "振り返り"
        boolean is_read
        int read_by FK "既読した教師"
        timestamp read_at
        timestamp created_at
        timestamp updated_at
    }
    
    teacher_notes {
        int id PK
        int teacher_id FK
        int student_id FK
        int entry_id FK "nullable"
        text note_text "メモ内容"
        boolean is_shared "共有フラグ"
        timestamp created_at
        timestamp updated_at
    }